# ===== FRONTEND (Vite/Vercel) =====
# URL ของ backend — ใส่ใน Vercel Dashboard > Environment Variables
VITE_API_URL=https://your-backend.up.railway.app

# Cloudinary cloud name (ต้องตรงกับ CLOUDINARY_CLOUD_NAME ฝั่ง backend)
# ใช้โดย CloudinaryImage.jsx เพื่อ build URL รูปที่ resize/optimize แล้ว
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name

# ===== BACKEND (server.js / Railway) =====
# Cloudinary — จำเป็นสำหรับให้รูปที่อัปโหลดอยู่ถาวร
# ถ้าไม่ตั้งค่า 3 ตัวนี้ครบ ระบบจะ fallback ไปเขียนไฟล์ลง disk ของ container
# ซึ่งจะหายทุกครั้งที่ redeploy/restart (เช่นบน Railway ที่ filesystem เป็น ephemeral)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Database — Railway/Render/Heroku สามารถใส่ DATABASE_URL หรือ MYSQL_URL ได้โดยตรง
DATABASE_URL=mysql://root:your-db-password@your-mysql-host.railway.internal:3306/railway
MYSQL_URL=mysql://root:your-db-password@your-mysql-host.railway.internal:3306/railway

# หรือใช้ DB_* แบบเดิมได้เช่นกัน
DB_HOST=your-mysql-host.railway.internal
DB_USER=root
DB_PASSWORD=your-db-password
DB_NAME=railway
DB_PORT=3306

# JWT
JWT_SECRET=your-super-secret-jwt-key

# Omise Payment
OMISE_PUBLIC_KEY=pkey_test_xxxx
OMISE_SECRET_KEY=skey_test_xxxx

# Port (Railway จะ set ให้อัตโนมัติ)
PORT=3000
